{
  "name": "life-nextcloud-sync",
  "version": "1.1.0",
  "description": "LiFE Nextcloud Sync",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --publish never",
    "build:mac:arm64": "electron-builder --mac dmg --arm64 --publish never"
  },
  "author": {
    "name": "valueerror",
    "email": "valueerrorx@users.noreply.github.com"
  },
  "homepage": "https://github.com/valueerrorx/life-nextcloud-sync",
  "license": "ISC",
  "build": {
    "appId": "eu.life-edu.lifenextcloudsync",
    "productName": "LiFE-Nextcloud-Sync",
    "icon": "icon.png",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "portable",
        "msi"
      ]
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "@electron/universal": "^2.0.1",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "webdav": "^5.8.0"
  }
}
